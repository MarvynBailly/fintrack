# Normalize text files; keep platform-specific line endings where required.
* text=auto

# Shell scripts must stay LF or they break on Linux (CI runner).
gradlew text eol=lf
*.sh text eol=lf

# Windows batch files need CRLF.
*.bat text eol=crlf

# Binaries — never touch line endings.
*.jar binary
*.png binary
*.jks binary
*.keystore binary
